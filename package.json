{
  "name": "bookmarks-manager",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "description": "Local-first PWA for merging, deduplicating and analyzing browser bookmarks",
  "author": "LessUp",
  "license": "MIT",
  "homepage": "https://lessup.github.io/bookmarks-manager/",
  "repository": {
    "type": "git",
    "url": "https://github.com/LessUp/bookmarks-manager.git"
  },
  "bugs": {
    "url": "https://github.com/LessUp/bookmarks-manager/issues"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:analyze": "tsc -b && ANALYZE=true vite build",
    "build:staging": "tsc -b && VITE_BASE_PATH=/ vite build",
    "typecheck": "tsc -b",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx --max-warnings=0",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "format:staged": "lint-staged",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist dev-dist tsconfig.tsbuildinfo tsconfig.node.tsbuildinfo coverage eslint-report.json .nyc_output",
    "validate": "npm run typecheck && npm run lint && npm run test",
    "ci": "npm run clean && npm ci && npm run validate && npm run build",
    "prepare": "husky install || true"
  },
  "dependencies": {
    "cytoscape": "^3.33.2",
    "dexie": "^4.4.2",
    "echarts": "^5.5.0",
    "lucide-react": "^0.468.0",
    "minisearch": "^6.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.2.25",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.0.0",
    "fast-check": "^3.23.2",
    "husky": "^9.1.0",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.0",
    "postcss": "^8.5.12",
    "prettier": "^3.8.3",
    "rimraf": "^6.0.0",
    "rollup-plugin-visualizer": "^5.12.0",
    "tailwindcss": "^3.4.13",
    "typescript": "5.5.4",
    "vite": "^5.4.8",
    "vite-plugin-pwa": "^0.21.2",
    "vitest": "^2.1.8",
    "workbox-build": "^7.4.0",
    "workbox-window": "^7.4.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
